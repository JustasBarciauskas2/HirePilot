# Auth0 (Regular Web Application) — https://auth0.com/docs/quickstart/webapp/nextjs
# Tenant hostname ONLY (no https://, no path — not /api/v2/)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Required: random 32-byte hex for encrypting cookies (openssl rand -hex 32) — NOT the same as CLIENT_SECRET
AUTH0_SECRET=
# Local dev; production can set a stable URL or omit for host inference
APP_BASE_URL=http://localhost:3000
