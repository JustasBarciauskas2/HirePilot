# --- Monorepo — copy into apps/website/.env.local, apps/portal/.env.local, and optionally apps/website-mock-client/.env.local ---
#
# Second mock marketing site (apps/website-mock-client, port 3002): npm run dev:mock-client — see apps/website-mock-client/env.example
#
# --- Monorepo (apps/website + apps/portal) — copy this file to apps/website/.env.local and apps/portal/.env.local ---
#
# Website (marketing): public URL of the recruiter portal (footer link). Example: https://portal.yourcompany.com
# NEXT_PUBLIC_PORTAL_URL=http://localhost:3001
#
# Marketing site: same id as server TENANT_ID (footer “Recruiter portal” uses `?tenant=…` once; portal middleware stores it in an HttpOnly cookie and removes it from the URL).
# NEXT_PUBLIC_TENANT_ID=techrecruit-prod
#
# Portal → marketing “Back to site / View on site” (set at least one of the following; no per-tenant JSON required):
# 1) NEXT_PUBLIC_MARKETING_SITE_URL — public marketing origin, e.g. http://localhost:3000 (recommended when you already know it)
# 2) Or for local dev only, omit it and set NEXT_PUBLIC_PORTAL_URL to this repo’s portal (http://localhost:3001) — the app infers the main marketing site as http://localhost:3000 on the same host
# 3) Optional: NEXT_PUBLIC_PORTAL_TENANT_SITE_ORIGINS as JSON (tenantId → origin) only if different marketing domains per tenant; otherwise 1) or 2) is enough
# NEXT_PUBLIC_MARKETING_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_PORTAL_URL=http://localhost:3001
#
# Multi-tenant portal: comma-separated tenant ids allowed for this deployment.
# PORTAL_ALLOWED_TENANT_IDS=tenant-a,tenant-b
#
# Bind each user to one tenant via Firebase custom claims (recommended for production). Then the ID token’s claim is the only source of tenant — users cannot switch orgs by editing cookies.
# Set the same claim name on each user (e.g. tenantId) with Admin SDK: auth.setCustomUserClaims(uid, { tenantId: "your-tenant-id" }). Users must refresh the ID token (re-login) after claims change.
# PORTAL_TENANT_FIREBASE_CLAIM=tenantId
#
# Rare: allow `X-Tenant-Id` header for server-to-server calls (browser clients use the HttpOnly cookie instead).
# PORTAL_TRUST_X_TENANT_ID_HEADER=0
#
# Dev only: allow reading `?tenant=` on the portal page if the cookie is missing (set PORTAL_TENANT_IN_URL=0 to disable).
# PORTAL_TENANT_IN_URL=1
#
# Local dev: `?tenant=mock-client-acme` always opens View / Back to site on http://localhost:3002 (even if NEXT_PUBLIC_MARKETING_SITE_URL is :3000). Other cases without 1) or 2) above fall back to http://localhost:3000.
#
# Same value in BOTH apps — portal calls the marketing POST /api/revalidate so job pages refresh after portal changes.
# REVALIDATE_SECRET=dev-only-change-me
#
# --- Firebase (client) — Project settings → Your apps → Web app config ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# Bucket id only (no gs://). New projects: project-id.firebasestorage.app — legacy: project-id.appspot.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server) — verify ID tokens in /api/portal/jobs ---
# Recommended: download the service account JSON from Firebase → Project settings → Service accounts
# → Generate new private key, save as firebase-service-account.json in the project root (gitignored).
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
#
# Option B: paste the entire service account JSON as one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# Option C: separate fields (copy private_key from JSON — keep \n escapes, or use real newlines in a quoted block)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# --- Job applications (candidate apply on /jobs/[ref], recruiters review in the portal app → Applications) ---
# 1) Firebase Console → Build → Firestore Database → Create database (pick region; start in production or test mode).
#    If you only see the Cloud API error, also enable: https://console.developers.google.com/apis/library/firestore.googleapis.com?project=YOUR_PROJECT_ID
# 2) Firebase Console → Build → Storage → Get started (default bucket is fine).
# CVs: `applications/{tenantId}/{jobRef}/...` in Storage. Metadata: Firestore collection `jobApplications`.
#
# Applicant + recruiter emails when someone applies (POST /api/job-applications). Uses Resend (https://resend.com).
# RESEND_API_KEY = auth only. Resend’s API still requires a From on every send; it does not read a “default from”
# from the dashboard — use APPLICATION_EMAIL_FROM if your verified sender in Resend isn’t the default below.
# Verify gethirepilot.com (or your domain) in Resend; the default From must be an address on that domain.
# RESEND_API_KEY=re_...
# Optional — default: HirePilot <notifications@gethirepilot.com> (must match a sender/domain you verified in Resend)
# APPLICATION_EMAIL_FROM=HirePilot <notifications@gethirepilot.com>
# Comma-separated — who receives the “new application” copy (recruiter). Applicant always gets a confirmation to their form email.
# RECRUITER_APPLICATION_NOTIFY_EMAIL=recruiter@company.com
#
# Optional server override (same bucket id as the console / gs:// URL without the prefix):
# FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
# Firestore index (if needed): jobApplications — tenantId Asc + createdAt Desc.
# For GET /api/vacancy/[vacancyId] (filter by vacancy UUID): tenantId Asc + vacancyId Asc + createdAt Desc.
#
# Server-to-server or tooling: list applications without the portal UI.
# APPLICATIONS_API_KEY=...  → send X-Applications-Api-Key: ... or Authorization: Bearer ...
# GET /api/tenant/{tenantId} — all applications for that tenant.
# GET /api/vacancy/{vacancyId}?tenantId={tenantId} — applications for one vacancy (JobDetail.id UUID).
# Or use Authorization: Bearer <Firebase ID token> (same users as /portal).
#
# Optional: POST **multipart/form-data** to your Java/API after each apply (same Firestore document id). Same pattern as job-document upload: field `file` = CV bytes; string fields `applicationId`, `tenantId`, `jobRef`, `jobSlug`, `jobTitle`, `companyName`, `vacancyId`, `firstName`, `lastName`, `email`, `phone`, `cvStoragePath`, `cvFileName`, `cvContentType` (see `appendJobApplicationFormFields` in lib/forward-job-application.ts). Header `X-Tenant-Id` matches `tenantId`.
# Return HTTP 2xx with JSON matching your JobApplicationResponse: `id` (persisted applicant) and optional `screening`; `backendPersonId` is accepted too (we store whichever identifies the applicant — prefer explicit `backendPersonId` when both are set). Optional `ok: false` in the body fails the forward even on HTTP 2xx.
# Screening shape: `data/candidate-screening-response.example.json` and `lib/candidate-screening-result.ts`. Recruiters see screening in the portal, not on the public apply thank-you page.
# BACKEND_JOB_APPLICATION_WEBHOOK_URL=https://api.example.com/v1/applications
# Or: BACKEND_ORIGIN=http://localhost:8080 and BACKEND_JOB_APPLICATION_PATH=/api/applications (default /api/job-applications)
# Optional: JOB_APPLICATION_WEBHOOK_SYNC=true — wait for the webhook before responding (first JSON may include screening for API clients only). Default is async: respond immediately with screeningStatus pending.
#
# Screening for recruiters is **not** stored in Firestore. Configure a GET that returns screening keyed by Firestore application id (`applicationId` on each row = same id you send as multipart `applicationId`). Next merges into GET /api/portal/applications, GET /api/tenant/{tenantId}, and GET /api/vacancy/{vacancyId}.
# BACKEND_TENANT_APPLICATIONS_URL=http://localhost:8080/api/tenant/{tenantId}/applications
# Or: BACKEND_TENANT_APPLICATIONS_USE_ORIGIN=true with BACKEND_ORIGIN + BACKEND_TENANT_APPLICATIONS_PATH (default /api/tenant/{tenantId}/applications)
#
# Recruiter portal (/portal → Applications): which rows to show.
# - If UNSET: Next.js queries Firestore `jobApplications` directly (tenantId + order). Rows match whatever exists in that Firebase project.
# - If SET: your backend returns Firestore document ids only. The portal shows **only** those rows (hydrated from Firestore). Orphan docs in Firestore are not listed. `BACKEND_ORIGIN` alone does not enable this.
# Query param `tenantId` is appended if missing; header `X-Tenant-Id` is sent. JSON examples: `{ "applicationIds": ["..."] }` or `["id1","id2"]`.
# BACKEND_APPLICATIONS_PORTAL_LIST_URL=http://localhost:8080/api/applications/portal
# Or: BACKEND_APPLICATIONS_PORTAL_LIST_USE_ORIGIN=true with BACKEND_ORIGIN + BACKEND_APPLICATIONS_PORTAL_LIST_PATH (default /api/applications/portal)

# Optional: absolute path to jobs.json (default: ./data/jobs.json locally, /tmp/... on Netlify/Vercel)
# JOBS_DATA_PATH=

# --- Tenant id (server-only; sent as JSON `tenant: { id }` on backend vacancy POSTs + `tenantId` on document upload) ---
# One stable id per deployment when sharing one API/DB across multiple frontends.
# TENANT_ID=techrecruit-prod
# Alias: SITE_INSTANCE_ID. If unset: NEXT_PUBLIC_FIREBASE_PROJECT_ID, then local-dev (dev) / unknown-instance (prod).

# --- Public site: GET vacancies for home + /jobs/[ref] + portal (server-side; uses TENANT_ID as tenantId query param) ---
# If BACKEND_URL is set, origin is derived (e.g. http://localhost:8080) and the list defaults to GET {origin}/api/vacancies?tenantId=…
# If that request fails, the site shows no vacancies (no fallback to local jobs.json).
# If the GET succeeds, local jobs.json is merged in for rows not yet returned by the API (e.g. right after publish).
# To use only local JSON and never call the list API, omit BACKEND_URL / BACKEND_ORIGIN and BACKEND_VACANCIES_LIST_URL.
# If unset, the site uses local data/jobs.json only.
#
# Full URL (append ?tenantId=… automatically if the URL has no tenantId query yet):
# BACKEND_VACANCIES_LIST_URL=http://localhost:8080/api/vacancies
#
# Or same origin as BACKEND_ORIGIN / BACKEND_URL + path (default /api/vacancies):
# BACKEND_VACANCIES_LIST_PATH=/api/vacancies
#
# The home page fetches your API server-side (not visible in the browser Network tab). To inspect what the server resolved, open GET /api/vacancies on this Next app (backend-only when the list URL is set — no mixing with jobs.json).
# Dev: DEBUG_VACANCIES_FETCH=1 logs the outbound URL + HTTP status in the Next.js terminal.
#
# Include a root-level `id` (e.g. UUID) on each vacancy object in the array — we map it to JobDetail.id and send it as query `id` with `tenantId` on portal DELETE (same UUID as vacancy.id).

# --- Backend API (vacancy POST) ---
# The browser only talks to this Next app (e.g. POST /api/portal/jobs). The server then forwards JSON to your API.
#
# Option A — one line (full URL, overrides B/C):
# BACKEND_URL=http://localhost:8080/api/vacancy
#
# Option B — origin + path (deploy: set BACKEND_ORIGIN to your live API origin):
# BACKEND_ORIGIN=http://localhost:8080
# BACKEND_VACANCY_PATH=/api/vacancy
#
# Option C — host + port + protocol (same result as B):
# BACKEND_PROTOCOL=http
# BACKEND_HOST=localhost
# BACKEND_PORT=8080
# BACKEND_VACANCY_PATH=/api/vacancy

# --- Backend: job document upload (portal file wizard → POST multipart to your API) ---
# Full URL overrides origin + path:
# BACKEND_DOCUMENT_URL=http://localhost:8080/api/vacancy/document
# Or use the same origin as above with a path (default /api/vacancy/document):
# BACKEND_DOCUMENT_PATH=/api/vacancy/document

# Publish after document review: defaults to {vacancy path}/publish (e.g. /api/vacancy → /api/vacancy/publish, or /vacancy → /vacancy/publish)
# Override path only (with BACKEND_ORIGIN): BACKEND_VACANCY_PUBLISH_PATH=/vacancy/publish
# Or full URL: BACKEND_VACANCY_PUBLISH_URL=http://localhost:8080/api/vacancy/publish

# DELETE vacancy (portal → Next → your API): `DELETE {base}/{vacancyUuid}?tenantId=…` — same base as POST (`/api/vacancy`), UUID in the path (Spring: @DeleteMapping("/api/vacancy/{id}") + @RequestParam tenantId).
# Optional template: BACKEND_VACANCY_DELETE_URL=http://localhost:8080/api/vacancy/{id}
#
# PUT vacancy (portal edit → Next → your API): same URL as DELETE — `PUT /api/vacancy/{vacancyId}?tenantId=…`. Body is **only** the vacancy object (JobDetail / your DTO), not `{ user, vacancy, tenant }`. Auth: `Authorization: Bearer` (Firebase ID token). If no id, PUT is skipped; local `jobs.json` can still update when BACKEND_OPTIONAL=true.
#
# On successful POST, return JSON with your row id, e.g. { "id": "uuid" } or { "vacancyId": "uuid" } (or { "vacancy": { "id": "..." } }) so we persist it and send it on DELETE.

# If true, still save the job on this site when your backend returns an error.
# BACKEND_OPTIONAL=false

# Dev only: logs the Firebase ID token to the Next.js server terminal when publishing (never enable in production)
# DEBUG_PRINT_ACCESS_TOKEN=true
# Dev only: log verifyIdToken errors on the server
# DEBUG_FIREBASE_TOKEN_ERRORS=true
