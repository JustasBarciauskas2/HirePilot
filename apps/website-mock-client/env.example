# Copy to .env.local (this app only). Dev: npm run dev --prefix apps/website-mock-client (port 3002)
# Structure matches apps/website/.env.local — only TENANT_ID / NEXT_PUBLIC_* URLs / label differ.
#
NEXT_PUBLIC_SITE_LABEL=ACME Careers
#
NEXT_PUBLIC_PORTAL_URL=http://localhost:3001
NEXT_PUBLIC_MARKETING_SITE_URL=http://localhost:3002
REVALIDATE_SECRET=dev-only-change-me
#
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
#
BACKEND_URL=http://localhost:8080/api/vacancy
GOOGLE_APPLICATION_CREDENTIALS=../../firebase-service-account.json
BACKEND_TENANT_APPLICATIONS_URL=http://localhost:8080/api/tenant/{tenantId}/applications
#
TENANT_ID=mock-client-acme
NEXT_PUBLIC_TENANT_ID=mock-client-acme
#
# See repo root env.example for portal, backend list URLs, and optional PORTAL_ALLOWED_TENANT_IDS.
